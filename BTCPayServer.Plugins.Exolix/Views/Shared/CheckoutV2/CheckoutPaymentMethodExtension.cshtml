@using BTCPayServer.Plugins.Exolix.Model
@using BTCPayServer.Plugins.Exolix.Services
@inject ExolixPluginService pluginService
@{
    ExolixSettings settings = await pluginService.GetStoreSettings(Model.StoreId);
    if (settings?.isConfigured is not true) return;
}

<a href="#Exolix" class="btcpay-pill m-0 payment-method" :class="{ active: pmId === 'Exolix' }"
       v-on:click.prevent="pmId.includes('BTC-') || pmId === 'ARKADE' ? changePaymentMethod('Exolix') : alert('Please select the Bitcoin or Lightning payment method first before choosing Altcoins.')">
    <div style="text-align: center;">
        <span style="display: block;">Altcoins</span>
    </div>
</a>
