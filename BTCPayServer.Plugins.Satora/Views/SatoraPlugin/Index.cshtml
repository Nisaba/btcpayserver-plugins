<partial name="_StatusMessage" />
<br />

<div permission="@Policies.CanModifyStoreSettings">
    <h4>Configuration</h4>
    <form method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Settings.StoreId" type="hidden" />
        <div class="form-group">
            <table>
                <tr>
                    <td width="100%">
                        <div class="d-flex align-items-center">
                            <input asp-for="@Model.Settings.Enabled" type="checkbox" class="btcpay-toggle me-3" />
                            <label asp-for="@Model.Settings.Enabled" class="form-check-label"></label>
                        </div>
                    </td>
                    <td align="right">
                        <button name="command" type="submit" value="save" class="btn btn-primary">Save</button>
                    </td>
                </tr>
            </table>
        </div>
    </form>

    @if (Model.Settings.Seed != null)
    {
        <div class="form-group mt-3">
            <h4>Seed Phrase</h4>
            <div class="alert alert-warning alert-dismissible fade show d-flex align-items-start gap-2" role="alert" id="seedWarningAlert">
                <span>⚠</span>
                <span class="flex-grow-1">
                    <strong>Warning:</strong> Never share your seed phrase with anyone.
                    Anyone who obtains it can take full control of your wallet.
                    Store it securely offline.
                </span>
                <button type="button" class="btn btn-link text-decoration-none p-0 border-0" data-bs-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true" style="font-weight: bold; font-size: 1.2rem; color: #000;">✕</span>
                </button>
            </div>
            <div class="input-group">
                <input type="password"
                       id="seedPhraseInput"
                       class="form-control font-monospace"
                       value="@Model.Settings.Seed"
                       readonly
                       autocomplete="off"
                       data-sensitive />
                <button class="btn btn-outline-secondary"
                        type="button"
                        id="toggleSeedBtn"
                        onclick="toggleSeedPhrase()"
                        title="Show / Hide seed phrase">
                    Show
                </button>
                <button class="btn btn-outline-secondary"
                        type="button"
                        onclick="copySeedPhrase()"
                        title="Copy seed phrase to clipboard">
                    Copy
                </button>
            </div>
            <div id="seedCopiedMsg" class="text-success small mt-1" style="display:none;">
                Copied to clipboard!
            </div>
        </div>
        <script>
            function toggleSeedPhrase() {
                const input = document.getElementById('seedPhraseInput');
                const btn   = document.getElementById('toggleSeedBtn');
                const isHidden = input.type === 'password';
                input.type   = isHidden ? 'text' : 'password';
                btn.textContent = isHidden ? 'Hide' : 'Show';
            }

            function copySeedPhrase() {
                const input = document.getElementById('seedPhraseInput');
                navigator.clipboard.writeText(input.value).then(() => {
                    const msg = document.getElementById('seedCopiedMsg');
                    msg.style.display = 'block';
                    setTimeout(() => msg.style.display = 'none', 2500);
                });
            }
        </script>
    }
</div>
<br />
<br />

<div permission="@Policies.CanViewInvoices">

    @if (Model.WalletBalance != null)
    {
        var confirmedBtc    = Model.WalletBalance.confirmedSats    / 100_000_000m;
        var preConfirmedBtc = Model.WalletBalance.preConfirmedSats / 100_000_000m;
        var recoverableBtc  = Model.WalletBalance.recoverableSats  / 100_000_000m;

        <div class="widget store-wallet-balance">
            <div class="d-flex gap-3 align-items-center justify-content-between mb-2">
                <h6>Arkade Wallet Balance</h6>
            </div>
            <div class="balances d-flex flex-wrap gap-4">
                <div class="balance">
                    <div class="d-flex align-items-baseline gap-1">
                        <h3 class="d-inline-block me-1" data-balance="@confirmedBtc" data-sensitive>@confirmedBtc.ToString("0.########")</h3>
                        <span class="text-secondary fw-semibold text-nowrap"><span class="currency">BTC</span> confirmed</span>
                    </div>
                </div>

                <div class="balance">
                    <div class="d-flex align-items-baseline gap-1">
                        <h3 class="d-inline-block me-1" data-balance="@preConfirmedBtc" data-sensitive>@preConfirmedBtc.ToString("0.########")</h3>
                        <span class="text-secondary text-nowrap"><span class="currency">BTC</span> pre-confirmed</span>
                    </div>
                </div>

                <div class="balance">
                    <div class="d-flex align-items-baseline gap-1">
                        <h3 class="d-inline-block me-1" data-balance="@recoverableBtc" data-sensitive>@recoverableBtc.ToString("0.########")</h3>
                        <span class="text-secondary text-nowrap"><span class="currency">BTC</span> recoverable</span>
                    </div>
                </div>
            </div>
        </div>
        <div style="height:20px"></div><br/>
    }



    <h4>Satora Customers Transactions</h4>

    @if (!Model.Transactions.Any())
    {
        <p>
            <i>No Satora transactions for this store...</i>
        </p>
    }
    else
    {
        var page = Context.Request.Query["page"].Count > 0 ? int.Parse(Context.Request.Query["page"]) : 1;
        var pageSize = 20;
        var totalItems = Model.Transactions.Count();
        var totalPages = (int)Math.Ceiling(totalItems / (double)pageSize);
        var pagedTransactions = Model.Transactions
            .Skip((page - 1) * pageSize)
            .Take(pageSize)
            .ToList();

        <div class="table-responsive">
            <table class="table table-hover mass-action">
                <thead class="mass-action-head">
                    <tr>
                        <th class="text-nowrap">Swap Id</th>
                        <th class="text-nowrap">Status</th>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Stablecoin</th>
                        <th class="text-nowrap">Blockchain</th>
                        <th class="text-nowrap">Amount (BTC)</th>
                        <th class="text-nowrap">Invoice</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in pagedTransactions)
                    {
                        <tr class="mass-action-row item">
                            <td class="text-break align-middle invoiceId-col">
                                <a asp-action="SwapDetails" asp-route-storeId="@Model.Settings.StoreId" asp-route-swapId="@item.TxID" class="badge badge-settled" title="Open swap details">@item.TxID</a>
                            </td>
                            <td align="center">
                                <div class="badge badge-expired" id="status-@item.TxID">@item.Status</div><br />
                                <a href="#" onclick="GetSwapStatus('@item.TxID');return false;" title="Refresh status">
                                    <vc:icon symbol="actions-refresh" class="icon-refresh" />
                                </a>
                            </td>
                            <td>@item.DateT.ToString("g")</td>
                            <td class="align-center">
                                <div class="badge badge-expired">
                                    @item.Stablecoin
                                </div>
                            </td>
                            <td class="align-center">
                                <div class="badge badge-expired">
                                    @item.Blockchain
                                </div>
                            </td>
                            <td class="align-right">@item.BTCAmount</td>
                            <td class="text-break align-middle invoiceId-col">
                                <a asp-controller="UIInvoice" asp-action="Invoice" asp-route-invoiceId="@item.BTCPayInvoiceId" class="text-break">@item.BTCPayInvoiceId</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <script>
            function GetSwapStatus(swapId) {
                $('#status-' + swapId).hide();
                $.ajax({
                    url: 'Satora/GetSwapStatus',
                    type: 'GET',
                    data: { swapId: swapId },
                    success: function (data) {
                        if (data) {
                            $('#status-' + swapId).text(data);
                        } else {
                            console.log('No status returned for swap ID:', swapId);
                        }
                        $('#status-' + swapId).show();
                    },
                    error: function (dataError) {
                        console.log('Error fetching swap status:', dataError);
                        $('#status-' + swapId).show();
                    }
                });
            }

        </script>
        <nav aria-label="Page navigation" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(page == 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(page - 1)" tabindex="-1">Previous</a>
                </li>
                @for (var i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
                <li class="page-item @(page == totalPages ? "disabled" : "")">
                    <a class="page-link" href="?page=@(page + 1)">Next</a>
                </li>
            </ul>
        </nav>

    }
</div>
<br />

